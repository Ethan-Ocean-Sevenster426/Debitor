# FSA Debtor System — environment template.
# Copy to ".env" (same folder as manage.py) and fill in real values.
# NEVER commit the real .env to source control.

# ---- Xero OAuth (from https://developer.xero.com → your app) ----
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
# Must EXACTLY match a redirect URI registered on the Xero app.
# Local dev: http://localhost:8000/xero/callback/
# Production: https://YOUR-DOMAIN/xero/callback/
XERO_REDIRECT_URI=https://debtors.example.com/xero/callback/

# ---- Django ----
# Generate a fresh key, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=debtors.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://debtors.example.com

# ---- SQL Server database ----
# Leave DB_USER / DB_PASSWORD blank ONLY for local Windows trusted auth.
# In the cloud, use SQL authentication (set both).
DB_SERVER=your-sql-host.database.windows.net
DB_NAME=FSA_Debtors
DB_PORT=1433
DB_USER=fsa_app
DB_PASSWORD=your-db-password
DB_DRIVER=ODBC Driver 18 for SQL Server
