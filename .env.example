# FSA Debtor System — environment template.
# Copy to ".env" (same folder as manage.py) and fill in real values.
# NEVER commit the real .env to source control.

# ---- Xero OAuth (from https://developer.xero.com → your app) ----
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
# Must EXACTLY match a redirect URI registered on the Xero app.
# Local dev: http://localhost:8000/xero/callback/
# Production: https://YOUR-DOMAIN/xero/callback/
XERO_REDIRECT_URI=https://debtors.example.com/xero/callback/

# ---- Django ----
# Generate a fresh key, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=debtors.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://debtors.example.com

# ---- SQL Server database ----
# Leave DB_USER / DB_PASSWORD blank ONLY for local Windows trusted auth.
# In the cloud, use SQL authentication (set both).
DB_SERVER=your-sql-host.database.windows.net
DB_NAME=FSA_Debtors
DB_PORT=1433
DB_USER=fsa_app
DB_PASSWORD=your-db-password
DB_DRIVER=ODBC Driver 18 for SQL Server

# ---- Email (Microsoft Graph, app-only) ----
# Powers user onboarding, password resets, weekly reports and debtor reminders.
# Sends via the Microsoft Graph sendMail API using an Entra app registration
# (no SMTP, no mailbox license). Set up in Entra:
#   1. App registrations -> New registration (single tenant).
#   2. Certificates & secrets -> New client secret -> copy the VALUE here.
#   3. API permissions -> Microsoft Graph -> Application permission "Mail.Send"
#      -> Grant admin consent.
#   4. MS_GRAPH_SENDER is the mailbox (e.g. a shared mailbox) mail is sent from.
MS_GRAPH_TENANT_ID=your-directory-tenant-id
MS_GRAPH_CLIENT_ID=your-application-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret-value
MS_GRAPH_SENDER=accounts@yourcompany.com
# Friendly "From" label (Graph sends as the MS_GRAPH_SENDER mailbox):
DEFAULT_FROM_EMAIL=FSA Debtor System <accounts@yourcompany.com>
# Absolute base URL of the app — used to build links inside emails:
SITE_BASE_URL=https://debtors.example.com
# Optional default recipients for the weekly report (comma-separated):
REPORT_RECIPIENTS=manager@yourcompany.com,legal@yourcompany.com
